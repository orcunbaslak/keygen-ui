# Keygen API Configuration
NEXT_PUBLIC_KEYGEN_API_URL=https://your-keygen-host.com/v1

# Account ID (retrieved after first login, not needed for singleplayer mode)
# NEXT_PUBLIC_KEYGEN_ACCOUNT_ID=

# Set to true for Keygen CE singleplayer mode (omits accounts/{id} from API paths)
# NEXT_PUBLIC_KEYGEN_SINGLEPLAYER=true
